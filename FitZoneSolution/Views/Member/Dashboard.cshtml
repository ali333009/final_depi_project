@model MemberDashboardVM
@{ ViewData["Title"] = "Member Dashboard"; }

<div class="page-header">
    <div>
        <span class="hero-badge"><i class="bi bi-person-fill me-1"></i> MEMBER</span>
        <h2 class="page-header-title">Welcome back, <span class="text-gradient-orange">@(Model.MemberName?.ToUpper() ?? "MEMBER")</span></h2>
        <p class="text-muted-fz">
            @if (Model.SubscriptionEndDate != null)
            {
                <span class="badge badge-accent"><i class="bi bi-check-circle-fill me-1"></i> Active until @Model.SubscriptionEndDate.Value.ToString("MMM dd, yyyy")</span>
            }
            else
            {
                <span class="badge badge-muted">No active subscription</span>
            }
        </p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4" data-reveal>
        <div class="card bg-card h-100">
            <div class="card-body d-flex align-items-start gap-3">
                <div style="flex-shrink:0;width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:rgba(255,76,41,0.1);border:1px solid rgba(255,76,41,0.2);">
                    <i class="bi bi-award text-accent fs-5"></i>
                </div>
                <div>
                    <div class="small text-muted-fz">Active Plan</div>
                    <div class="fs-5 fw-bold">@(Model.ActivePlanName ?? "None")</div>
                    <div class="small text-muted-fz">@Model.SubscriptionStatus</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4" data-reveal>
        <div class="card bg-card h-100">
            <div class="card-body d-flex align-items-start gap-3">
                <div style="flex-shrink:0;width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:rgba(255,107,71,0.1);border:1px solid rgba(255,107,71,0.2);">
                    <i class="bi bi-clock-history fs-5" style="color:var(--accent-secondary);"></i>
                </div>
                <div>
                    <div class="small text-muted-fz">Days Remaining</div>
                    <div class="fs-5 fw-bold">@(Model.SubscriptionEndDate != null ? ((Model.SubscriptionEndDate.Value - DateTime.UtcNow).Days).ToString() : "-")</div>
                    @if (Model.SubscriptionEndDate == null)
                    {
                        <a asp-controller="Member" asp-action="Subscribe" class="btn btn-sm btn-accent mt-2">Subscribe now</a>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4" data-reveal>
        <div class="card bg-card h-100">
            <div class="card-body d-flex align-items-start gap-3">
                <div style="flex-shrink:0;width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.2);">
                    <i class="bi bi-calendar-check fs-5" style="color:#34d399;"></i>
                </div>
                <div>
                    <div class="small text-muted-fz">Upcoming Bookings</div>
                    <div class="fs-5 fw-bold">@Model.UpcomingBookingCount</div>
                    <a asp-controller="Member" asp-action="BookClass" class="btn btn-sm btn-accent mt-2">Book a class</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6" data-reveal>
        <div class="card bg-card h-100">
            <div class="card-header d-flex align-items-center gap-2 border-fz">
                <i class="bi bi-person-badge text-accent"></i>
                My Coach
            </div>
            <div class="card-body">
                @if (Model.TrainerName != null)
                {
                    <div class="d-flex align-items-center gap-3">
                        <div style="flex-shrink:0;width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(255,76,41,0.1);border:1px solid rgba(255,76,41,0.2);">
                            <i class="bi bi-person-badge text-accent fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-5">@Model.TrainerName</div>
                            @if (Model.TrainerSpecialization != null)
                            {
                                <span class="badge badge-accent">@Model.TrainerSpecialization</span>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-3">
                        <p class="text-muted-fz mb-0">No coach assigned yet</p>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6" data-reveal>
        <div class="card bg-card h-100">
            <div class="card-header d-flex align-items-center gap-2 border-fz">
                <i class="bi bi-activity text-accent"></i>
                Recent Progress
            </div>
            <div class="card-body">
                @if (!Model.RecentProgress.Any())
                {
                    <div class="text-center py-5">
                        <p class="text-muted-fz">No progress entries yet</p>
                        <a asp-controller="Member" asp-action="MyProgress" class="btn btn-sm btn-accent">Add an entry</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr><th>Date</th><th>Weight</th><th>Body Fat</th></tr>
                            </thead>
                            <tbody>
                            @foreach (var p in Model.RecentProgress)
                            {
                                <tr>
                                    <td>@p.Date.ToString("MMM dd")</td>
                                    <td class="fw-semibold">@p.Weight kg</td>
                                    <td>@(p.BodyFat != null ? p.BodyFat + "%" : "-")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
