@model TrainerScheduleVM
@{ ViewData["Title"] = "My Schedule"; }

<div class="page-header text-center">
    <span class="hero-badge"><i class="bi bi-calendar-week me-1"></i> TRAINER PORTAL</span>
    <h2 class="page-header-title" data-reveal>MY <span class="text-gradient-orange">SCHEDULE</span></h2>
    <p class="text-muted-fz" data-reveal>Your weekly class timetable</p>
</div>

@if (!Model.Slots.Any())
{
    <div class="text-center py-5" data-reveal>
        <i class="bi bi-calendar-x display-1 text-muted-fz"></i>
        <h4 class="fw-bold mt-3">No Classes Scheduled</h4>
        <p class="text-muted-fz" style="max-width:400px;margin:0 auto;">
            You don't have any class schedules yet. Contact the admin to get assigned to classes.
        </p>
    </div>
}
else
{
    var days = new[] {
        DayOfWeek.Saturday, DayOfWeek.Sunday, DayOfWeek.Monday,
        DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday
    };

    @foreach (var day in days)
    {
        var daySlots = Model.Slots.Where(s => s.DayOfWeek == day).ToList();
        if (!daySlots.Any()) continue;

        <div class="mb-4" data-reveal>
            <h5 class="fw-bold mb-3 text-gradient-orange">@day</h5>
            <div class="row g-3">
                @foreach (var slot in daySlots)
                {
                    <div class="col-lg-6">
                        <div class="card bg-card h-100">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <h6 class="fw-bold mb-1">@slot.ClassName</h6>
                                        <span class="small text-muted-fz">
                                            <i class="bi bi-clock text-accent me-1"></i>
                                            @slot.StartTime.ToString(@"hh\:mm") - @slot.EndTime.ToString(@"hh\:mm")
                                        </span>
                                    </div>
                                    <span class="badge badge-accent">
                                        @slot.BookedCount / @slot.Capacity
                                    </span>
                                </div>
                                <div class="progress" style="height:5px;border-radius:3px;background:rgba(255,255,255,0.08);">
                                    <div class="progress-bar bg-accent" role="progressbar"
                                         style="width: @(slot.Capacity > 0 ? Math.Round((double)slot.BookedCount / slot.Capacity * 100) : 0)%"
                                         aria-valuenow="@slot.BookedCount" aria-valuemin="0" aria-valuemax="@slot.Capacity">
                                    </div>
                                </div>
                                <a asp-controller="Trainer" asp-action="Attendance" asp-route-classId="@slot.ClassId"
                                   class="btn btn-sm btn-outline-fz mt-2 px-3">
                                    <i class="bi bi-check2-square me-1"></i>Attendance
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}
