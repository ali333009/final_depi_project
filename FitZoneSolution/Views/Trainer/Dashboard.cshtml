@model TrainerDashboardVM
@{ ViewData["Title"] = "Trainer Dashboard"; }

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4" data-reveal>
    <div>
        <span class="hero-badge"><i class="bi bi-person-workspace me-1"></i> TRAINER PORTAL</span>
        <h2 class="display-3 mb-1">Welcome, <span class="text-gradient-orange">@Model.TrainerName.ToUpper()</span></h2>
        <p class="text-muted-fz mb-0"><span class="badge badge-accent"><span class="status-dot"></span> @Model.Specialization</span></p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6" data-reveal>
        <div class="card bg-card h-100">
            <div class="card-body d-flex align-items-start gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle" style="flex-shrink:0;width:48px;height:48px;background:rgba(255,76,41,0.1);border:1px solid rgba(255,76,41,0.2);">
                    <i class="bi bi-people text-accent"></i>
                </div>
                <div>
                    <div class="small text-muted-fz">Assigned Members</div>
                    <div class="stat-number">@Model.AssignedMemberCount</div>
                    <a asp-controller="Trainer" asp-action="MyMembers" class="btn btn-sm btn-accent mt-2">View members</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6" data-reveal>
        <div class="card bg-card h-100">
            <div class="card-body d-flex align-items-start gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle" style="flex-shrink:0;width:48px;height:48px;background:rgba(255,76,41,0.1);border:1px solid rgba(255,76,41,0.2);">
                    <i class="bi bi-calendar-check text-accent"></i>
                </div>
                <div>
                    <div class="small text-muted-fz">Classes Led</div>
                    <div class="stat-number">@Model.ClassCount</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card bg-card" data-reveal>
    <div class="card-header d-flex align-items-center gap-2">
        <i class="bi bi-calendar3 text-accent"></i>
        My Class Schedule
    </div>
    <div class="card-body">
        @if (!Model.UpcomingClasses.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-calendar-x text-muted-fz d-block mb-2" style="font-size:2rem;"></i>
                <p class="text-muted-fz mb-0">No classes scheduled</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Class</th>
                            <th>Day</th>
                            <th>Time</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var c in Model.UpcomingClasses)
                    {
                        <tr>
                            <td class="fw-semibold">@c.ClassName</td>
                            <td><span class="badge badge-muted">@c.DayOfWeek</span></td>
                            <td>@c.StartTime.ToString(@"hh\:mm") - @c.EndTime.ToString(@"hh\:mm")</td>
                            <td>
                                <a asp-controller="Trainer" asp-action="Attendance" asp-route-classId="@c.ClassId" class="btn btn-sm btn-accent">Attendance</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
