@model ReportsVM
@{ ViewData["Title"] = "Reports"; }

<div class="page-header">
    <div>
        <h2>REPORTS &amp; <span class="text-gradient-orange">INSIGHTS</span></h2>
        <p class="text-muted-fz">Revenue &amp; activity analytics</p>
    </div>
</div>

<div class="card bg-card mb-4">
    <div class="card-body">
        <form asp-controller="Admin" asp-action="Reports" method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">From</label>
                <input type="date" name="from" class="form-control form-control-sm" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">To</label>
                <input type="date" name="to" class="form-control form-control-sm" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-accent btn-sm w-100">FILTER</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card bg-card h-100">
            <div class="card-body d-flex align-items-start gap-3">
                <div style="flex-shrink:0;width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:rgba(255,76,41,0.1);font-size:1.2rem;font-weight:700;color:var(--fz-accent);">
                    <i class="bi bi-currency-dollar"></i>
                </div>
                <div>
                    <div class="small text-muted-fz">Total Revenue</div>
                    <div class="fs-5 fw-bold text-gradient-orange">@Model.TotalRevenue.ToString("C0")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-card h-100">
            <div class="card-body d-flex align-items-start gap-3">
                <div style="flex-shrink:0;width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:rgba(255,107,71,0.1);font-size:1.2rem;font-weight:700;color:var(--fz-accent-2);">
                    <i class="bi bi-receipt"></i>
                </div>
                <div>
                    <div class="small text-muted-fz">Active Subscriptions</div>
                    <div class="fs-5 fw-bold">@Model.ActiveSubscriptionCount</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-card h-100">
            <div class="card-body d-flex align-items-start gap-3">
                <div style="flex-shrink:0;width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:rgba(52,211,153,0.1);font-size:1.2rem;font-weight:700;color:var(--fz-emerald);">
                    <i class="bi bi-person-plus"></i>
                </div>
                <div>
                    <div class="small text-muted-fz">New Members</div>
                    <div class="fs-5 fw-bold">@Model.NewMembersCount</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card bg-card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-bar-chart" style="color:var(--fz-accent);"></i>
                Revenue by Month
            </div>
            <div class="card-body">
                @if (!Model.RevenueByMonth.Any())
                {
                    <div class="text-center py-4">
                        <p class="text-muted-fz mb-0">No revenue data in the selected range</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Month</th>
                                    <th>Revenue</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var m in Model.RevenueByMonth)
                            {
                                <tr>
                                    <td>@m.Month</td>
                                    <td class="fw-semibold text-gradient-orange">@m.Revenue.ToString("C0")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card bg-card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-star" style="color:var(--fz-accent);"></i>
                Most Popular Classes
            </div>
            <div class="card-body">
                @if (!Model.MostPopularClasses.Any())
                {
                    <div class="text-center py-4">
                        <p class="text-muted-fz mb-0">No data in the selected range</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var c in Model.MostPopularClasses.Select((item, idx) => new { item, idx }))
                        {
                            <div class="list-group-item d-flex align-items-center gap-3">
                                <div class="d-flex align-items-center justify-content-center rounded-circle"
                                     style="width:32px;height:32px;background:rgba(255,76,41,0.08);color:var(--fz-accent);font-family:'Oswald',sans-serif;font-weight:700;font-size:0.85rem;flex-shrink:0;">
                                    @(c.idx + 1)
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold small">@c.item.ClassName</div>
                                    <div style="font-size:0.7rem;color:var(--fz-text-muted);">@c.item.BookingCount bookings</div>
                                </div>
                                <span class="badge badge-muted">@c.item.BookingCount</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
