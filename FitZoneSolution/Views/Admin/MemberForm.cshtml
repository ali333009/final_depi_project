@model MemberFormVM
@{
    ViewData["Title"] = Model.MemberId == null ? "New Member" : "Edit Member";
    var isEdit = Model.MemberId != null;
}

<div class="page-header text-center">
    <div class="hero-badge mb-2">@(isEdit ? "EDIT MEMBER" : "NEW MEMBER")</div>
    <h2 class="page-header-title">@(isEdit ? "Edit Member" : "Create New Member")</h2>
    <p class="text-muted-fz">@(isEdit ? "Update member details" : "Add a new member to the gym")</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card bg-card">
            <div class="card-body p-4">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <form asp-controller="Admin" asp-action="@(isEdit ? "EditMember" : "CreateMember")"
                      asp-route-id="@Model.MemberId" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label small fw-semibold">Full Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Full name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-semibold">Email Address</label>
                        <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label small fw-semibold">Phone Number</label>
                        <input asp-for="Phone" class="form-control" placeholder="+20 XXX XXX XXXX" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label small fw-semibold">
                            @(isEdit ? "New Password (leave blank to keep current)" : "Password")
                        </label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-accent w-100 py-2 fw-semibold">
                        @(isEdit ? "UPDATE MEMBER" : "CREATE MEMBER")
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
