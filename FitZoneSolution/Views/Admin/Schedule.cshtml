@model WeeklyScheduleVM
@{
    ViewData["Title"] = "Weekly Schedule";
    var days = new[] { DayOfWeek.Saturday, DayOfWeek.Sunday, DayOfWeek.Monday, DayOfWeek.Tuesday,
                       DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday };
}

<div class="page-header">
    <div>
        <div class="hero-badge mb-1">ADMIN PANEL</div>
        <h2 class="page-header-title">WEEKLY <span class="text-gradient-orange">SCHEDULE</span></h2>
        <p class="text-muted-fz">Manage class timings</p>
    </div>
    <a asp-controller="Admin" asp-action="ManageClasses" class="btn btn-outline-fz px-4 py-2 fw-semibold">BACK TO CLASSES</a>
</div>

<div class="card bg-card mb-4">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-1 d-flex align-items-center gap-2">
            <i class="bi bi-clock" style="color:var(--fz-accent);"></i>
            Add Schedule Slot
        </h5>
        <p class="text-muted-fz small mb-3">Add a new time slot for an existing class</p>

        <form asp-controller="Admin" asp-action="AddScheduleSlot" method="post" class="row g-3 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Class</label>
                <select name="ClassId" class="form-select">
                    @foreach (var c in Model.AllClasses)
                    {
                        <option value="@c.Id">@c.ClassName</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Day</label>
                <select name="DayOfWeek" class="form-select">
                    @foreach (var d in days)
                    {
                        <option value="@d">@d</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Start Time</label>
                <input type="time" name="StartTime" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">End Time</label>
                <input type="time" name="EndTime" class="form-control" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-accent w-100 py-2 fw-semibold">ADD SLOT</button>
            </div>
        </form>
    </div>
</div>

@if (!Model.Slots.Any())
{
    <div class="card bg-card">
        <div class="text-center py-5">
            <p class="text-muted-fz mb-0">No schedule slots yet</p>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var d in days)
        {
            var daySlots = Model.Slots.Where(s => s.DayOfWeek == d).OrderBy(s => s.StartTime).ToList();
            <div class="col-md-6 col-lg-4">
                <div class="card bg-card h-100">
                    <div class="card-body p-3">
                        <h6 class="fw-bold text-gradient-orange mb-3 text-center text-uppercase" style="letter-spacing:1px;">@d.ToString().Substring(0, 3)</h6>
                        @if (!daySlots.Any())
                        {
                            <div class="text-muted-fz small text-center py-3" style="opacity:0.5;">No classes</div>
                        }
                        else
                        {
                            @foreach (var slot in daySlots)
                            {
                                <div class="glass rounded-3 p-3 mb-2 position-relative">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <span class="fw-bold small">@slot.ClassName</span>
                                        <span class="text-gradient-orange small fw-semibold">@slot.StartTime.ToString(@"hh\:mm") - @slot.EndTime.ToString(@"hh\:mm")</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted-fz" style="font-size:0.7rem;">
                                            <i class="bi bi-person" style="font-size:0.6rem;"></i>
                                            @slot.TrainerName
                                        </span>
                                        <span class="small @(slot.BookedCount >= slot.Capacity ? "text-danger" : "text-muted-fz")" style="font-size:0.7rem;">
                                            @slot.BookedCount/@slot.Capacity
                                        </span>
                                    </div>
                                    @if (slot.BookedCount >= slot.Capacity)
                                    {
                                        <span class="badge badge-rose" style="position:absolute;top:4px;right:4px;font-size:0.55rem;">FULL</span>
                                    }
                                    <form asp-controller="Admin" asp-action="DeleteScheduleSlot" method="post" class="mt-1"
                                          onsubmit="return confirm('Remove this slot?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="scheduleId" value="@slot.ScheduleId" />
                                        <button type="submit" class="btn btn-sm py-0 px-1 fw-semibold btn-danger"
                                                style="font-size:0.6rem;">Remove</button>
                                    </form>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
