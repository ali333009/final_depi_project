@{
    ViewData["Title"] = "Error";
}

<div class="d-flex flex-column align-items-center justify-content-center text-center py-5" style="min-height: calc(100vh - 12rem);">
    <span class="hero-badge mb-3"><i class="bi bi-exclamation-triangle me-1"></i> ERROR</span>
    <h1 class="fz-display fw-bold mb-3" style="font-size: clamp(2rem, 5vw, 4rem);">
        Something went <span class="text-gradient-orange">wrong</span>
    </h1>
    <p class="text-muted-fz mb-4" style="max-width:28rem;">
        An unexpected error occurred while processing your request. Please try again or return to the homepage.
    </p>
    <div class="d-flex gap-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-accent px-4 py-2 fw-semibold">
            <i class="bi bi-house me-2"></i>Go Home
        </a>
        <button onclick="history.back()" class="btn btn-outline-fz px-4 py-2 fw-semibold">
            <i class="bi bi-arrow-left me-2"></i>Go Back
        </button>
    </div>
</div>
